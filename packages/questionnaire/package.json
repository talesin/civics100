{
  "name": "questionnaire",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/src/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/src/index.d.ts"
    },
    "./data": {
      "import": "./dist/data/index.js",
      "types": "./dist/src/data/index.d.ts"
    }
  },
  "scripts": {
    "clean": "rm -rf dist/ node_modules/ build/ coverage/",
    "lint": "npx eslint .",
    "lint:fix": "npx eslint . --fix",
    "build": "tsc --build && npx tsup src/index.ts src/data/index.ts --format esm --out-dir dist && npm run list-todos",
    "build:vercel": "npm run build",
    "package": "npm install && npm run lint && npm run test && npm run build",
    "test": "npx jest",
    "start": "npx tsx src/cli/index.ts",
    "list-todos": "find src/ test/ -iname '*.ts' -exec grep --color -inHE '(TODO|FIXME|HACK)' '{}' \\;"
  },
  "dependencies": {
    "@effect/cli": "^0.73.2",
    "@effect/platform": "^0.94.5",
    "@effect/platform-node": "^0.104.1",
    "civics2json": "*",
    "distractions": "*",
    "effect": "^3.19.19",
    "ts-essentials": "^10.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "eslint": "^9.25.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^29.7.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.56.1"
  }
}
