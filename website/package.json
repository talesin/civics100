{
  "name": "website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "rm -rf dist/ node_modules/ build/ coverage/ .next/",
    "dev": "npx next dev",
    "build": "npm run lint && npm run test && NODE_ENV=production npx next build",
    "build:vercel": "npx next build",
    "package": "npm install && npm run build",
    "start": "npx next start",
    "lint": "npx eslint .",
    "lint:fix": "npx eslint . --fix",
    "export": "npx next build",
    "test": "NODE_OPTIONS='--experimental-vm-modules' npx jest",
    "test:watch": "NODE_OPTIONS='--experimental-vm-modules' npx jest --watch",
    "test:coverage": "NODE_OPTIONS='--experimental-vm-modules' npx jest --coverage",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:headed": "npx playwright test --headed",
    "test:e2e:report": "npx playwright show-report",
    "list-todos": "find src/ test/ -iname '*.ts' -exec grep --color -inHE '(TODO|FIXME|HACK)' '{}' \\;"
  },
  "dependencies": {
    "@effect/platform": "^0.94.5",
    "@tamagui/animations-css": "^1.144.4",
    "@tamagui/config": "^1.144.4",
    "@tamagui/next-plugin": "^1.144.4",
    "@tamagui/next-theme": "^1.144.4",
    "civics2json": "*",
    "effect": "^3.19.19",
    "next": "^16.1.6",
    "questionnaire": "*",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tamagui": "^1.144.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "jest-environment-jsdom": "^29.7.0",
    "typescript": "^5"
  }
}
